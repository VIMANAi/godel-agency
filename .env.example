# ==============================================================================
# SAIEL: CONFIGURACIÓN DE VARIABLES DE ENTORNO (.env)
# Copie este archivo como '.env' en la raíz y configure los valores según su entorno.
# ==============================================================================

# ⚙️ MODO DE PROCESAMIENTO (12-Factor App)
# 'local' para procesamiento Bunker (Ollama + DeepSeek + SQLite)
# 'cloud' para procesamiento Escalabilidad (Vertex AI + BigQuery)
SAIEL_ENGINE_MODE=local

# 📁 RUTAS Y DIRECTORIOS (Portabilidad total sin paths hardcodeados)
# El sistema autodetectará la raíz si se deja vacío, pero se puede forzar:
SAIEL_BASE_PATH=/home/fratfn/Escritorio/Agency
# Ruta de sincronización con Google Drive (para windows_receiver.py)
SAIEL_DRIVE_DIR=G:/Mi unidad/SAIEL_Inteligencia_Politica

# 🛡️ MOTOR DE INTELIGENCIA LOCAL (Bunker)
SAIEL_OLLAMA_MODEL=deepseek-r1:7b

# 🔑 SCRAPING / DATA COLLECTION
# Ingrese su API Token de Apify para social_collector y mass_collector
APIFY_TOKEN=tu_apify_token_aqui

# ☁️ MOTOR DE INTELIGENCIA CLOUD (Native Escalabilidad)
# Obligatorio si SAIEL_ENGINE_MODE es 'cloud'
GOOGLE_APPLICATION_CREDENTIALS=/home/fratfn/Escritorio/Agency/gcp-credentials.json
SAIEL_PROJECT_ID=mi-proyecto-gcp-123
SAIEL_GCS_BUCKET=bucket-saiel-raw-data
