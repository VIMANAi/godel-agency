{
  "agent_id": "saiel_political_intelligence_agent",
  "version": "3.0",
  "name": "SAIEL Agnostic Agent Core",
  "description": "Enterprise-grade Role-Agnostic Intelligent Agent Stack",
  "pii_filtering": {
    "redact_emails": true,
    "redact_phones": true,
    "redact_names": true,
    "patterns": {
      "email": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
      "phone": "(\\+\\d{1,3}[-.]?)?\\(?\\d{3}\\)?[-.]?\\d{3}[-.]?\\d{4}",
      "curp": "\\b[A-Z]{4}\\d{6}[HM][A-Z]{5}\\d{2}\\b",
      "ine": "\\b[A-Z]{6}\\d{8}\\b"
    }
  },
  "specialists": {
    "social_scraper": {
      "description": "Especialista en recolección de redes sociales y CRM.",
      "allowed_tools": ["tool_collect_data", "tool_list_data_files"],
      "denied_tools": ["tool_run_sensemaker", "tool_read_report", "tool_check_crisis", "tool_query_memory", "tool_commit_to_memory"]
    },
    "narrative_analyst": {
      "description": "Especialista en clustering DBSCAN y descubrimiento de narrativas.",
      "allowed_tools": ["tool_run_sensemaker", "tool_read_report", "tool_run_sentiment"],
      "denied_tools": ["tool_collect_data", "tool_commit_to_memory", "tool_request_executive_approval"]
    },
    "compliance_officer": {
      "description": "Especialista en verificaciones legales, regulatorias y manejo de crisis.",
      "allowed_tools": ["tool_check_crisis", "tool_request_executive_approval", "tool_query_memory"],
      "denied_tools": ["tool_collect_data", "tool_run_sentiment", "tool_commit_to_memory"]
    },
    "product_owner": {
      "description": "Especialista en análisis de requerimientos y refinamiento de historias de usuario.",
      "allowed_tools": ["tool_refine_user_story"],
      "denied_tools": ["tool_generate_system_design", "tool_sequence_git_strategy", "tool_collect_data"]
    },
    "system_architect": {
      "description": "Especialista en diseño técnico de sistemas y escaneos de código estáticos.",
      "allowed_tools": ["tool_generate_system_design"],
      "denied_tools": ["tool_refine_user_story", "tool_sequence_git_strategy", "tool_collect_data"]
    },
    "tech_lead": {
      "description": "Especialista en planificación técnica de tareas y estrategias de branches de Git.",
      "allowed_tools": ["tool_sequence_git_strategy"],
      "denied_tools": ["tool_refine_user_story", "tool_generate_system_design", "tool_collect_data"]
    }
  }
}
