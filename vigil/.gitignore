# ============================================================
# Vigil — .gitignore
# ============================================================

# --- Secretos y entorno ---
.env
config/local_config.yaml
config/templates/local_*.yaml

# --- Entorno virtual Python ---
.venv/
venv/
env/

# --- Datos (nunca sincronizar raw ni procesados) ---
data/raw/*
data/silver/*
data/gold/*
!data/raw/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep

# --- Reportes y evals generados (contienen datos sensibles) ---
reports/*.md
reports/*.json
evals/*.json
!reports/.gitkeep
!evals/.gitkeep

# --- notebooklm-mcp-cli: auth aislado al proyecto ---
.notebooklm/

# --- mcp-toolbox binario (descargado, no versionado) ---
bin/toolbox
!bin/.gitkeep

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Sistema ---
.DS_Store
Thumbs.db
*.swp
*~
