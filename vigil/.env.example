# ============================================================
# Vigil — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# --- Google Gemini API ---
# Obtén tu clave en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Apify ---
# Obtén tu token en: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# --- Neo4j Aura (Cloud Free) ---
# Crea tu instancia en: https://console.neo4j.io
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Meta Ad Library (opcional para datos básicos) ---
# Obtén credenciales en: https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# --- Configuración del pipeline Vigil ---
Vigil_ENV=tepic_2026
Vigil_MODEL_ID=gemini-2.5-flash
Vigil_LOG_LEVEL=INFO
