# --- 📊 Local Databases & Large Data (No subir datos crudos/procesados)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/silver/*
!data/silver/.gitkeep
data/gold/*
!data/gold/.gitkeep
data/sessions/*
